DATABASE_URL=postgresql://user:password@localhost:5432/kubereats
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
# Business timezone for "today's orders" (IANA name).
TIMEZONE=Asia/Taipei

# ── GCP Cloud Storage (menu images) ──
# Bucket must grant allUsers objectViewer so uploaded images are publicly
# readable at https://storage.googleapis.com/<bucket>/<key>.
GCS_BUCKET=kubereats-menu-images
# Optional; inferred from the credentials when left empty.
GCP_PROJECT=
# Path to the service-account key JSON (Application Default Credentials).
# On-prem the key is mounted into the pod; locally point it at your downloaded key.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa-key.json
