DATABASE_URL=postgresql://user:password@localhost:5432/kubereats
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
# Business timezone for "today's orders" (IANA name).
TIMEZONE=Asia/Taipei

# ── MinIO / object storage (menu images) ──
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kubereats
# Browser-facing base URL for image links; leave empty to reuse MINIO_ENDPOINT.
MINIO_PUBLIC_URL=
